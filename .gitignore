# Build artifacts
*.o
kmeans_mpi
kmeans_seq
bin/

# Generated datasets (regenerate with scripts/gen_dataset.py)
data/*.bin
data/*.npy

# Raw experiment outputs (large/derived). Commit curated snapshots into
# results/snapshots/ by hand for the report instead.
results/*.csv
results/*.txt
results/labels_*.txt
results/centroids_*.txt
!results/snapshots/

# Plots are regenerated by plots/make_plots.py; keep report-final copies under
# results/snapshots/ if you want them version-controlled.
plots/*.png

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
*.swp
